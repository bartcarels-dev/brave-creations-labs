# Admin password — required for saving in admin & API
ADMIN_PASSWORD=your-secure-password-here

# Option A: Vercel Blob (recommended — Storage → Blob in Vercel dashboard)
# BLOB_READ_WRITE_TOKEN is added automatically when you connect a Blob store.

# Option B: Upstash Redis (Storage → Upstash Redis in Vercel dashboard)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
